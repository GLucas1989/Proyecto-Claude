# Supabase — obtené estos valores en app.supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# URL pública del sitio (sin trailing slash)
NEXT_PUBLIC_SITE_URL=https://creatorsshub.com

# YouTube Data API (ya existente)
YOUTUBE_API_KEY=

# MailerLite (ya existente)
MAILERLITE_API_KEY=

# Stripe (Módulos 2, 3 y 5)
# Obtené las keys en: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# El webhook debe apuntar a: https://creatorsshub.com/api/stripe/webhook
# Excluir de middleware: /api/stripe/webhook (ya configurado en src/middleware.ts)
