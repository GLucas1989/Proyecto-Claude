# Supabase — obtené estos valores en app.supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# URL pública del sitio (sin trailing slash)
NEXT_PUBLIC_SITE_URL=https://creatorsshub.com

# YouTube Data API (ya existente)
YOUTUBE_API_KEY=

# MailerLite (ya existente)
MAILERLITE_API_KEY=

# Email transaccional (Brecha-09) — usá uno de los dos proveedores
# Resend (recomendado): obtené la key en resend.com/api-keys
RESEND_API_KEY=
# Remitente verificado para emails transaccionales
EMAIL_FROM=Creators S-HUB <no-reply@creatorsshub.gg>

# Lemon Squeezy (pagos — suscripciones de juegos, creadores y promoción UGC)
# Obtené las keys en: app.lemonsqueezy.com > Settings > API
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
# El webhook debe apuntar a: https://creatorsshub.com/api/lemonsqueezy/webhook

# Variant IDs de productos en Lemon Squeezy (Settings > Products > Variants > ID)
LS_VARIANT_GAME_MTG_ARENA=
LS_VARIANT_GAME_WILD_RIFT=
LS_VARIANT_GAME_LOL=
LS_VARIANT_GAME_DIABLO_IV=
LS_VARIANT_GAME_DIABLO_IMMORTAL=
LS_VARIANT_GAME_RAID=
LS_VARIANT_GAME_ALBION=
LS_VARIANT_GAME_DARK_AND_DARKER=
LS_VARIANT_GAME_BEYOND_ALL_REASON=
LS_VARIANT_GAME_MULTIGENERO=
LS_VARIANT_CREATOR_SUB=
LS_VARIANT_UGC_PROMOTION=
# Tarifas mensuales de monetización
LS_VARIANT_FEE_STANDARD=
LS_VARIANT_FEE_OFFICIAL=

# Cron (recálculo diario de reputación de creadores)
CRON_SECRET=

# Supabase — service role key (bypassa RLS). Necesaria para que los webhooks
# (Lemon Squeezy, Didit) puedan escribir en profiles/wallets/subscriptions.
# Obtené el valor en: app.supabase.com > Project Settings > API > service_role
# NUNCA exponer en el cliente ni loguearla.
SUPABASE_SERVICE_ROLE_KEY=

# Didit.me (KYC — verificación de identidad de creadores)
# Obtené las keys en: business.didit.me > API keys / Webhooks
# (el workflow_id "Free KYC" NO va acá — está hardcodeado en src/lib/didit.ts
# porque no es un secreto, es config por sesión según la doc de Didit)
DIDIT_API_KEY=
DIDIT_WEBHOOK_SECRET=
# El webhook debe apuntar a: https://creatorsshub.gg/api/webhooks/didit

# Spotify "Gaming Mode" (widget flotante, activo en todas las vistas)
# Obtené las credenciales en: developer.spotify.com/dashboard
# Redirect URI a registrar en la app de Spotify: https://creatorsshub.gg/api/auth/callback/spotify
# Requiere cuenta Spotify Premium para reproducir (limitación del Web Playback SDK)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# next-auth / Auth.js (usado solo para el login OAuth de Spotify de arriba)
# Generá un valor con: openssl rand -base64 32
AUTH_SECRET=

# Mux (hosting de video — carga y reproducción de contenido exclusivo)
# Obtené las keys en: dashboard.mux.com > Settings > API Access Tokens
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# Webhook: dashboard.mux.com > Settings > Webhooks, URL:
# https://creatorsshub.gg/api/webhooks/mux
MUX_WEBHOOK_SECRET=
# Signing key — necesaria solo para reproducir contenido "exclusivo"
# (dashboard.mux.com > Settings > Signing Keys). MUX_SIGNING_KEY_PRIVATE es el
# valor base64 que Mux te da UNA sola vez al crear la key — guardalo ahí.
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_PRIVATE=
